set $mod Mod4

# Forest Color Scheme (Birch Tree Inspired)
set $forest-bg #1a1e1d
set $forest-dark #2d322f
set $forest-muted #3d4a42
set $forest-green #4a6754
set $forest-light #5d7a64
set $forest-birch #d4e0d8
set $forest-accent #6b8e7a
set $forest-alert #8b6b6b

font pango:BigBlueTermPlus Nerd Font,Cascadia Code,monospace 16

# Gaps
gaps inner 10
gaps outer 5

# Window border colors (Forest theme)
client.focused $forest-green $forest-green $forest-birch $forest-muted
client.focused_inactive $forest-muted $forest-muted $forest-birch $forest-muted
client.unfocused $forest-dark $forest-dark $forest-birch $forest-muted
client.urgent $forest-alert $forest-alert $forest-birch $forest-muted
client.placeholder $forest-bg $forest-bg $forest-birch $forest-muted

floating_modifier $mod

bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

bindsym $mod+s sticky toggle

# workspace navigation
bindsym $mod+Ctrl+Left workspace prev
bindsym $mod+Ctrl+Right workspace next
bindsym $mod+Tab workspace back_and_forth

bindsym $mod+e layout toggle split
bindsym $mod+t layout tabbed
bindsym $mod+d floating toggle
bindsym $mod+f fullscreen toggle

# workspace selection
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "0"

bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6
bindsym $mod+7 workspace $ws7
bindsym $mod+8 workspace $ws8
bindsym $mod+9 workspace $ws9
bindsym $mod+0 workspace $ws10

bindsym $mod+Shift+1 move container to workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4
bindsym $mod+Shift+5 move container to workspace $ws5
bindsym $mod+Shift+6 move container to workspace $ws6
bindsym $mod+Shift+7 move container to workspace $ws7
bindsym $mod+Shift+8 move container to workspace $ws8
bindsym $mod+Shift+9 move container to workspace $ws9
bindsym $mod+Shift+0 move container to workspace $ws10

# essential applications
bindsym $mod+Return exec alacritty
bindsym $mod+space exec launcher
bindsym $mod+Shift+x exec lock-screen
bindsym $mod+Shift+e exec i3-msg exit
bindsym $mod+Shift+q exec xdotool getwindowfocus windowclose

# screenshots
bindsym Print exec screenshot
bindsym Shift+Print exec screenshot region

# utilities
bindsym $mod+Shift+m exec rofi -modi emoji -show emoji -no-disable-history
bindsym $mod+Shift+p exec workon

for_window [class="Alacritty"] floating enable

default_border pixel 0
default_floating_border pixel 0

bar {
    status_command i3status
    
    # Forest colors for bar
    colors {
        background $forest-bg
        statusline $forest-birch
        separator $forest-muted
        
        # border background text
        focused_workspace $forest-green $forest-green $forest-birch
        active_workspace $forest-light $forest-light $forest-birch
        inactive_workspace $forest-dark $forest-dark $forest-muted
        urgent_workspace $forest-alert $forest-alert $forest-birch
        binding_mode $forest-accent $forest-accent $forest-birch
    }
}
